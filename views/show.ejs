<%- include("partials/header") %>

<div class="container my-5 d-flex justify-content-center">
  <div class="card shadow p-4 blog-detail-card">
    <div class="card-body text-center">
      <h1 class="card-title mb-3"><%= blog.title %></h1>
      <h4 class="card-subtitle mb-4 text-muted"><%= blog.content %></h4>
        <% if (blog.image) { %>
  <img src="<%= blog.image %>" alt="Blog Image" class="img-fluid rounded mb-4" style="max-height: 400px; object-fit: cover;">
<% } %>

      <p><strong>Author:</strong> <%= blog.author %></p>
      <p class="text-muted">Posted on: <%= blog.created_at.toLocaleString() %></p>

      <div class="my-4 d-flex justify-content-center gap-3 flex-wrap">
        <a class="btn btn-warning" href="/blog/<%= blog.id %>/edit">✏️ Edit</a>

        <form action="/blog/<%= blog.id %>?_method=DELETE" method="POST">
          <button class="btn btn-danger" type="submit">🗑️ Delete</button>
        </form>

        <a class="btn btn-dark" href="/">⬅ Back to All Blogs</a>
      </div>
    </div>
  </div>
</div>
    <%- include("partials/footer") %> 