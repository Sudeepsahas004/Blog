<%- include("partials/header") %>

<div class="container d-flex justify-content-center mt-5">
  <div class="card shadow p-4" style="width: 100%; max-width: 600px; background: #f8f9fa;">
    <h2 class="text-center mb-4 text-primary">Edit Blog Post</h2>

    <form action="/blog/<%= blog.id %>?_method=PATCH" method="POST">
      <div class="mb-3">
        <label for="title" class="form-label">Title:</label>
        <input type="text" id="title" name="title" class="form-control" value="<%= blog.title %>" required>
      </div>

      <div class="mb-3">
        <label for="author" class="form-label">Author:</label>
        <input type="text" id="author" name="author" class="form-control" value="<%= blog.author %>" required>
      </div>

      <div class="mb-3">
        <label for="content" class="form-label">Content:</label>
        <textarea id="content" name="content" rows="8" class="form-control" required><%= blog.content %></textarea>
      </div>
       <div class="mb-3">
        <label for="image" class="form-label">Image URL:</label>
        <input type="text" id="image" name="image" class="form-control" value="<%= blog.image %>">
      </div>
      <div class="d-flex justify-content-between align-items-center">
        <button type="submit" class="btn btn-success">✅ Update</button>
        <a href="/" class="btn btn-outline-primary">⬅ Back to Home</a>
      </div>
    </form>
  </div>
</div>

<%- include("partials/footer") %>
